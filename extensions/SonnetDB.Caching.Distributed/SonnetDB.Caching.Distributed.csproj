<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>SonnetDB.Caching.Distributed</RootNamespace>
    <AssemblyName>SonnetDB.Caching.Distributed</AssemblyName>
    <PackageId>SonnetDB.Caching.Distributed</PackageId>
    <Title>SonnetDB.Caching.Distributed</Title>
    <Description>SonnetDB KV-backed IDistributedCache provider.</Description>
    <PackageTags>sonnetdb;caching;distributed-cache;kv</PackageTags>
    <PackageReadmeFile>PackageReadme.md</PackageReadmeFile>
